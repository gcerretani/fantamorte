# Copia in .env e compila i valori

# Django
# In produzione (DEBUG=False, il default) SECRET_KEY è OBBLIGATORIA:
# senza, l'app si rifiuta di avviarsi invece di partire con una chiave insicura.
SECRET_KEY=cambia-con-una-chiave-segreta-lunga
DEBUG=False
# Domini/IP autorizzati a servire l'app, separati da virgola. Obbligatorio
# quando DEBUG=False (in dev, se lasciato vuoto, viene usato localhost/127.0.0.1).
ALLOWED_HOSTS=il-tuo-dominio.example.com,www.il-tuo-dominio.example.com
SITE_ID=1

# Livello di log della root logger (DEBUG|INFO|WARNING|ERROR)
DJANGO_LOG_LEVEL=INFO

# Header HSTS (attivi solo quando DEBUG=False). Valori di default già sicuri,
# da personalizzare solo se sai cosa stai facendo.
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Versione della cache del service worker: cambiala ad ogni deploy per
# invalidare la cache lato client dei client PWA (consigliato: hash del
# commit del deploy, es. output di `git rev-parse --short HEAD`).
SW_CACHE_VERSION=

# Database MariaDB
DB_PASSWORD=password-sicura
DB_ROOT_PASSWORD=root-password-sicura

# Docker Compose
IMAGE_TAG=latest          # oppure un tag specifico tipo 1.0.0
PORT=8000

# Dominio pubblico servito da nginx (obbligatorio col compose di produzione).
# Usato per il virtual host e per i certificati Let's Encrypt.
SERVER_NAME=il-tuo-dominio.example.com

# Scheduler dei job periodici (servizio 'scheduler' nel compose)
SCHEDULER_DAILY_HOUR=6            # ora dei job giornalieri (reminder, bonus primo/ultimo)
SCHEDULER_INTERVAL_SECONDS=3600   # frequenza del ciclo (check_deaths)

# Rotazione backup DB (servizio 'db_backup' nel compose)
BACKUP_KEEP_DAYS=14

# Wikidata (opzionale)
WIKIDATA_USER_AGENT=Fantamorte/1.0 (tua@email.com)

# Cache Redis condivisa (opzionale in sviluppo: senza, Django usa la
# LocMemCache per-processo). Nel compose di produzione REDIS_URL è
# impostata automaticamente al servizio redis.
# REDIS_URL=redis://localhost:6379/1

# --- OAuth (django-allauth) ---
# Lascia vuote per disabilitare un provider
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Allauth: optional|mandatory|none
ACCOUNT_EMAIL_VERIFICATION=optional
ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

# --- Email (per registrazione, reset password, ecc.) ---
# Per sviluppo lasciare il backend console.
# In produzione serve un backend SMTP reale, altrimenti il reset password
# e le altre email non vengono mai recapitate:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# (e compilare EMAIL_HOST, EMAIL_HOST_USER, EMAIL_HOST_PASSWORD, EMAIL_PORT/EMAIL_USE_TLS)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Fantamorte <noreply@fantamorte.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- Web Push (VAPID) ---
# Generale con: python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=admin@fantamorte.local
